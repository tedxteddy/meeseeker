# Meeseeker Environment Variables
# These are OPTIONAL and can also be set via the Settings UI in the browser.

# Job Search APIs
JSEARCH_API_KEY=your_rapidapi_key_here
APIFY_API_TOKEN=your_apify_token_here

# AI Resume Parsing
OPENAI_API_KEY=your_openai_api_key_here
CLAUDE_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Additional Job APIs
ADZUNA_API_KEY=your_app_id:app_key_here
JOOBLE_API_KEY=your_jooble_api_key_here

# Server (optional - defaults to 3001)
PORT=3001
